# Optional: override API base URL
# Default (no .env): https://ddbackend-production.up.railway.app
#
# For LOCAL backend (must be running on your machine):
# NEXT_PUBLIC_API_URL=http://localhost:4300
#
# For HOSTED backend (Railway): leave unset or set explicitly:
# NEXT_PUBLIC_API_URL=https://ddbackend-production.up.railway.app
