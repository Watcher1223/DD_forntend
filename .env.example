# Optional: override API base URL
# Default (no .env): https://ddbackend-production.up.railway.app
#
# For LOCAL backend (must be running on your machine):
# NEXT_PUBLIC_API_URL=http://localhost:4300
#
# For HOSTED backend (Railway): leave unset or set explicitly.
# With default, frontend uses https://ddbackend-production.up.railway.app and
# wss://ddbackend-production.up.railway.app — QR invite then uses hosted URL so users can join.
# NEXT_PUBLIC_API_URL=https://ddbackend-production.up.railway.app
#
# Backend .env (if you run the backend): PUBLIC_BASE_URL makes the QR link and
# WebSocket URL use the public host (e.g. https://ddbackend-production.up.railway.app
# or http://192.168.1.5:4300 for LAN). See docs/INVITE_OTHERS_QR.md.
# To enable Veo video generation for story beats, set: VEO_ENABLED=true
#
# QR code "Invite with phone" — URL the phone can open (phones can't open localhost).
# When using the hosted API (default), we use API_BASE for the QR so it points to the
# hosted URL. To force it: NEXT_PUBLIC_PAIR_PHONE_BASE_URL=https://ddbackend-production.up.railway.app
# For local dev with phone on same WiFi: NEXT_PUBLIC_PAIR_PHONE_BASE_URL=http://192.168.1.5:4300
# NEXT_PUBLIC_PAIR_PHONE_BASE_URL=
